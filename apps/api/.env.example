DATABASE_URL="postgresql://postgres:postgres@localhost:5434/parimutuel_pools?schema=public"

# Server
PORT=3002

# Solana - comma-separated for failover (tries next on 429/error)
SOLANA_RPC_URLS="https://api.devnet.solana.com,https://devnet.helius-rpc.com/?api-key=YOUR_KEY"
# Legacy single endpoint (used if SOLANA_RPC_URLS not set)
SOLANA_RPC_URL="https://api.devnet.solana.com"
PROGRAM_ID="HnqB6ahdTEGwJ624D6kaeoSxUS2YwNoq1Cn5Kt9KQBTD"
# Auto-payout: when true, the scheduler pays winners on-chain using the
# authority as the sole signer (no user-signed claim required). Defaults
# to false. To opt OUT a specific category, set autoPayoutEnabled=false
# in its pool_category.config JSON via the admin Categories tab.
AUTO_PAYOUT_ENABLED=false
# Authority secret key as JSON array (e.g., [1,2,3,...])
# Generate with: solana-keygen new --outfile authority.json
AUTHORITY_SECRET_KEY=""
# USDC mint address (Mainnet: EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v)
USDC_MINT="EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v"

# Market Data
PACIFICA_API_URL=https://api.pacifica.fi
PACIFICA_WS_URL=wss://ws.pacifica.fi/ws

# Admin
ADMIN_API_KEY=

# Scheduler
SCHEDULER_ENABLED=true
PRICE_SOURCE=pacifica
# Optional: Custom pool templates as JSON
# POOL_TEMPLATES='[{"asset":"BTC","interval":3600,"cronExpression":"0 * * * *","joinWindowSeconds":3000}]'

# Polymarket / UMA Optimistic Oracle (Polygon)
# Free-tier RPC works (Ankr/QuickNode/Alchemy). Public polygon-rpc.com
# also works for low traffic (~600 reads/hr).
POLYGON_RPC_URL=
# Feature flag — when true, resolutionPoll reads UMA first and uses Gamma
# only as fallback. Keep false until you have observed parity for ~7d.
POLYMARKET_USE_UMA=false

# --- X (Twitter) auto-poster ---
# Posts new pools as plain-text tweets ("JUST IN: {title}" + link). Write-only.
# OAuth 1.0a USER context (NOT Bearer / OAuth 2.0 Client ID). The Access Token
# must be generated with the app in "Read and Write" mode. The tweets post AS the
# account that authorized the Access Token (verify via Admin > X Poster).
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
# Public site base URL used for the link in each tweet (no trailing slash).
WEB_BASE_URL=https://updown.my

# --- Polymarket pool quality (freshness + ranking) ---
# Only ingest markets caught in the first N fraction of their [startDate,endDate]
# life (0.05 = first 5%, "freshly listed" only).
PM_MAX_ELAPSED_FRACTION=0.05
# Global 24h-volume floor (USD). Markets below max(category.minVolume24h, this)
# are skipped, so only world-known / actively-traded topics become pools. 0 = use
# per-category config only.
PM_MIN_VOLUME_24H_FLOOR=25000
