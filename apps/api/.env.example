# ============================================================================
#  apps/api — environment template
#  Copy to `.env` and fill in. NEVER commit the real .env (it holds secrets).
#  Grouped by concern; each var notes its default and whether it's required.
#  On Railway, set these in the API service → Variables.
# ============================================================================

# ── Core / server ───────────────────────────────────────────────────────────
NODE_ENV=development                     # development | production
PORT=3002                                # HTTP + WebSocket port
# Postgres connection. Local dev runs on :5434 (Docker). The `start` script also
# runs `prisma migrate deploy` against this before booting.
DATABASE_URL="postgresql://postgres:postgres@localhost:5434/parimutuel_pools?schema=public"
# Optional: separate direct (non-pooled) URL for migrations. Falls back to
# DATABASE_URL when unset (used by Supabase poolers in prod).
# DIRECT_URL=
# Comma-separated list of allowed browser origins (web + terminal). Defaults to
# http://localhost:3000 when unset.
CORS_ORIGIN=http://localhost:3000,http://localhost:3010

# ── Solana / on-chain ───────────────────────────────────────────────────────
# Comma-separated RPCs for failover — the client rotates to the next on
# 429/5xx/network error. Prefer paid endpoints (Helius/QuickNode) first.
SOLANA_RPC_URLS="https://api.devnet.solana.com,https://devnet.helius-rpc.com/?api-key=YOUR_KEY"
# Legacy single endpoint — only used if SOLANA_RPC_URLS is empty.
SOLANA_RPC_URL="https://api.devnet.solana.com"
# Override the auto-detected cluster (devnet | mainnet-beta). Usually leave unset.
# SOLANA_CLUSTER=devnet
# Deployed Anchor program id (current devnet program).
PROGRAM_ID="9H7k26HvHHnB4T6ErU7n2wVSFJhS1aigqFQGwvQyVuNG"
# USDC mint. Devnet (our test mint): By87mHK9Meinfv4AEqTx9qyYmGDLUcwiywpkkCWwGUVz
#            Mainnet:                 EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
# MUST match NEXT_PUBLIC_USDC_MINT in apps/web.
USDC_MINT="By87mHK9Meinfv4AEqTx9qyYmGDLUcwiywpkkCWwGUVz"
# Authority / upgrade-authority keypair as a JSON byte array, e.g. [12,34,...].
# Generate: solana-keygen new --outfile authority.json  (then paste its contents)
AUTHORITY_SECRET_KEY=""
# Alternative to AUTHORITY_SECRET_KEY: path to a keypair file on disk.
# AUTHORITY_KEYPAIR_PATH=/path/to/authority.json

# ── Payouts & rent recovery ─────────────────────────────────────────────────
# When true, the scheduler pays winners on-chain (authority signs; no user claim).
# Opt a category out via autoPayoutEnabled=false in its pool_category.config.
AUTO_PAYOUT_ENABLED=false
# "on" lets the scheduler close losing bets + sweep vault dust to reclaim rent.
CLOSE_LOSING_BETS=off
# Time-weighted crypto payouts (earlier bets earn more). Tuning knobs:
# TIME_WEIGHTED_EXPONENT=1          # curve steepness
# TIME_WEIGHTED_FLOOR=0.2          # minimum weight for a last-second bet

# ── Admin panel ─────────────────────────────────────────────────────────────
# Shared secret for the admin API (sent as the x-admin-key header). REQUIRED.
ADMIN_API_KEY=
# Admin auth brute-force throttle (all optional; sane defaults if unset).
# ADMIN_AUTH_RATE_WINDOW_MS=900000   # window length
# ADMIN_AUTH_RATE_LIMIT=10          # max attempts per IP per window
# ADMIN_AUTH_RATE_FAILS=5           # failed attempts before lockout
# ADMIN_AUTH_RATE_TOTAL=100         # global attempt cap per window

# ── Price feed / market data ────────────────────────────────────────────────
PRICE_SOURCE=pacifica                    # crypto pool price source
PACIFICA_API_URL=https://api.pacifica.fi
PACIFICA_WS_URL=wss://ws.pacifica.fi/ws

# ── Scheduler (pool creation/resolution) ────────────────────────────────────
SCHEDULER_ENABLED=true                   # master switch for all cron jobs
# Optional: override crypto pool templates as JSON.
# POOL_TEMPLATES='[{"asset":"BTC","interval":3600,"cronExpression":"0 * * * *","joinWindowSeconds":3000}]'
# Optional CSV whitelist of sports to create pools for (defaults to live-covered).
# SPORTS_POOL_WHITELIST=NBA,NFL,MLB,NHL
# Hours after kickoff with no result before a stuck pool is abandoned/closed.
# POOL_CLOSE_ABANDON_HOURS=72

# ── Sports data providers ───────────────────────────────────────────────────
THESPORTSDB_KEY=933848                    # TheSportsDB (primary livescore source)
# THE_ODDS_API=                          # The Odds API key (livescore fallback)
# CHAT_GPT_API_KEY=                      # OpenAI key — LLM result fallback for
#                                        # results SDB never posts (admin Review)
# API_FOOBTALL_ALL_SPORTS=               # legacy alias fallback for THESPORTSDB_KEY (note: typo'd name kept for compat)

# ── Polymarket (predictions) ────────────────────────────────────────────────
# Polygon RPC for reading UMA/CTF on-chain resolution. Free tiers work
# (Ankr/QuickNode/Alchemy); public polygon-rpc.com is fine for low traffic.
POLYGON_RPC_URL=
# Read UMA first, Gamma as fallback. Keep false until parity observed ~7d.
POLYMARKET_USE_UMA=false
# Sync cadence + paging (defaults shown).
POLYMARKET_SYNC_INTERVAL_HOURS=6
POLYMARKET_RESOLUTION_POLL_MINUTES=10
POLYMARKET_MAX_PAGES_PER_TAG=4
# POLYMARKET_MAX_MARKETS_PER_CATEGORY=50
# Pool-quality filters (freshness + ranking):
PM_MAX_ELAPSED_FRACTION=0.05             # only markets in the first 5% of their life
PM_MIN_VOLUME_24H_FLOOR=25000            # min 24h volume (USD); 0 = per-category only
PM_LOPSIDED_THRESHOLD=0.15               # skip markets already >85/15 (effectively decided)
# Grace before a stuck PM pool is cancelled (defaults shown in code):
# PM_SWEEP_GAMMA_DELISTED_GRACE_HOURS=24
# PM_SWEEP_UMA_STUCK_GRACE_HOURS=72

# ── HyperLiquid / trading terminal ──────────────────────────────────────────
# Our builder code (PUBLIC address) that collects the builder fee. Must match
# NEXT_PUBLIC_HYPERLIQUID_BUILDER_ADDRESS in apps/terminal.
HYPERLIQUID_BUILDER_ADDRESS=
# Builder fee in TENTHS of a basis point. 10 = 0.01% = 1bp (kept low for
# competitiveness). Max for perps is 100 (0.1%).
HYPERLIQUID_BUILDER_FEE=10
# "on" enables trading-XP crediting from HL fills (mainnet only).
TRADING_XP=off
# TRADING_XP_INTERVAL_SECONDS=60        # poll cadence for the trading-XP job
# Secret used to encrypt stored HL agent-wallet private keys (AES). REQUIRED for
# trading features. Generate 32+ random bytes (e.g. openssl rand -hex 32).
EXCHANGE_KEY_ENCRYPTION_SECRET=

# ── Treasury & liquidity bot ────────────────────────────────────────────────
# Mainnet treasury keypair (JSON byte array) used to fund the liquidity bot.
# On devnet the bot mints test USDC instead, so this can stay empty.
TREASURY_SECRET_KEY=
# Liquidity-bot wallet keypairs as a JSON array of byte arrays: [[..],[..]].
LIQUIDITY_BOT_KEYS=

# ── Growth / referrals ──────────────────────────────────────────────────────
# Testing growth features (20-bet reward, milestones, referrals). Default ON;
# set to "false" to disable in production once testing is done.
TESTING_MODE=true
# Salt for hashing referral device/anti-cheat fingerprints.
REFERRAL_SALT=updown-referrals-v1

# ── X (Twitter) auto-poster ─────────────────────────────────────────────────
# Posts new pools as plain-text tweets ("JUST IN: {title}"). Write-only.
# OAuth 1.0a USER context (NOT Bearer / OAuth 2.0 Client ID). Generate the
# Access Token with the app in "Read and Write" mode. Tweets post AS the account
# that authorized the token (verify in Admin → Economy → X Poster).
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
# Public site base URL for the link in each tweet (no trailing slash).
WEB_BASE_URL=https://updown.my

# ── Misc tuning ─────────────────────────────────────────────────────────────
# Delay (ms) between RPC calls during orphan-pool recovery, to avoid 429s.
# RECOVERY_RPC_DELAY_MS=500

# --- World Cup contest auth (server-side Privy token verification) ---
# Verifies the Privy access token on prediction writes (contest integrity).
# PRIVY_APP_ID=
# PRIVY_APP_SECRET=
