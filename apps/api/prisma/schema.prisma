generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum PoolStatus {
  UPCOMING
  JOINING
  ACTIVE
  RESOLVED
  CLAIMABLE
  CANCELLED // Pool can never resolve (e.g. PM market delisted from Gamma, UMA stuck > grace window). winner stays NULL; bets refunded or 0-bet → on-chain account closed.
}

enum Side {
  UP
  DOWN
  DRAW
}

enum SquadRole {
  OWNER
  MEMBER
}

model Pool {
  id              String     @id @default(uuid())
  poolId          String     @unique @map("pool_id")
  asset           String
  interval        String     @default("1h")
  durationSeconds Int        @default(3600) @map("duration_seconds")
  status          PoolStatus @default(UPCOMING)
  startTime       DateTime   @map("start_time")
  endTime         DateTime   @map("end_time")
  lockTime        DateTime   @map("lock_time")
  strikePrice     BigInt?    @map("strike_price")
  finalPrice      BigInt?    @map("final_price")
  totalUp         BigInt     @default(0) @map("total_up")
  totalDown       BigInt     @default(0) @map("total_down")
  totalDraw       BigInt     @default(0) @map("total_draw")
  numSides        Int        @default(2) @map("num_sides")
  poolType        String     @default("CRYPTO") @map("pool_type")
  matchId         String?    @map("match_id")
  homeTeam        String?    @map("home_team")
  awayTeam        String?    @map("away_team")
  homeTeamCrest   String?    @map("home_team_crest")
  awayTeamCrest   String?    @map("away_team_crest")
  league          String?
  matchAnalysis   String?    @map("match_analysis")
  homeScore       Int?       @map("home_score")
  awayScore       Int?       @map("away_score")
  winner          Side?
  marketOdds      Float?     @map("market_odds")
  groupItemTitle  String?    @map("group_item_title")
  clobTokenIds    String?    @map("clob_token_ids")
  tags            String? // JSON array of raw tag labels from Polymarket (display/debug)
  subcategory     String? // Single resolved subcategory bucket (exact-match filter key)
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  // Set once the pool's on-chain PDA has been closed (or confirmed already
  // closed via the auto_cleanup path). Acts as a terminal flag for the
  // scheduler so processClaimableTransitions / processPoolClosures stop
  // re-picking the row. Without it, RESOLVED↔CLAIMABLE oscillates forever
  // and POOL_CLOSED auto_cleanup spams the event log.
  closedAt        DateTime?  @map("closed_at")

  squadId    String? @map("squad_id")
  maxBettors Int?    @map("max_bettors")

  squad          Squad?          @relation("SquadPools", fields: [squadId], references: [id])
  bets           Bet[]
  priceSnapshots PriceSnapshot[]

  @@index([asset, interval, status])
  @@index([squadId, status])
  @@index([poolType])
  @@index([poolType, league])
  @@index([league, subcategory])
  @@index([status, closedAt])
  @@map("pools")
}

model Bet {
  id              String    @id @default(uuid())
  poolId          String    @map("pool_id")
  walletAddress   String    @map("wallet_address")
  side            Side
  amount          BigInt
  /// Time-weighted contribution to the side's pool. Mirror of the
  /// on-chain UserBet.weight field — captured by the deposit confirm
  /// route from the Deposited event so we can compute analytics
  /// (sniper rate, average entry multiplier, etc.) without an RPC
  /// per bet. Null on bets created before Phase 2 ships; the chain
  /// still has the authoritative value.
  weight          BigInt?   @map("weight")
  /// Multiplier in basis points that was applied to this specific
  /// deposit (10_000 == 1.0). For multi-deposit bets this stores the
  /// FIRST deposit's multiplier — the weight field accumulates the
  /// weighted sum across deposits.
  entryMultiplierBps Int?   @map("entry_multiplier_bps")
  depositTx       String?   @map("deposit_tx")
  claimed         Boolean   @default(false)
  claimTx         String?   @map("claim_tx")
  payoutAmount    BigInt?   @map("payout_amount")
  // Auto-payout tracking - set by the scheduler's autoClaimBets job. Stays
  // null/0 for bets paid via the manual claim flow.
  payoutFailed    Boolean   @default(false) @map("payout_failed")
  payoutAttempts  Int       @default(0) @map("payout_attempts")
  lastAttemptedAt DateTime? @map("last_attempted_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  pool Pool @relation(fields: [poolId], references: [id])

  // One row per (pool, wallet, side): a wallet can hold positions on multiple
  // sides of the same pool (hedge). Maps 1:1 to the per-side on-chain UserBet PDA.
  @@unique([poolId, walletAddress, side])
  // Speeds up the autoClaimBets queue scan (poolId + claimed=false + winning side).
  @@index([poolId, claimed, payoutFailed])
  // Speeds up the admin "failed payouts" tab.
  @@index([payoutFailed, lastAttemptedAt])
  // Admin user search + profile bet history. Without these, /api/admin/users/search
  // (per-wallet aggregates + recentBets) does a sequential scan of all bets — at
  // 1M+ bets that's >1s per admin lookup. See PLAN-ADMIN-REFACTOR.md Phase 1 #7.
  @@index([walletAddress])
  @@index([walletAddress, createdAt])
  @@map("bets")
}

model PriceSnapshot {
  id        String   @id @default(uuid())
  poolId    String   @map("pool_id")
  type      String // 'STRIKE' or 'FINAL'
  price     BigInt
  timestamp DateTime
  source    String
  rawHash   String   @map("raw_hash")
  createdAt DateTime @default(now()) @map("created_at")

  pool Pool @relation(fields: [poolId], references: [id])

  @@map("price_snapshots")
}

/// Persistent backing store for the in-process price-history ring buffer
/// (services/price-history.ts). Fed by a throttled writer (~5s/asset) so
/// after an API restart the scheduler can hydrate the buffer from
/// recent history and resolve pools at their actual endTime even when
/// the WebSocket subscription hasn't started pushing ticks yet.
///
/// Pruned daily: anything older than 24h is dropped, the buffer only
/// ever reads the last hour at startup.
model PriceTick {
  id        String   @id @default(uuid())
  asset     String
  price     String // stringified 2-decimal USD — matches the WS broadcast payload format
  timestamp DateTime
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([asset, timestamp])
  @@index([asset, timestamp(sort: Desc)])
  @@map("price_ticks")
}

// ─── XP & Rewards ──────────────────────────────────────────────────────────

enum RewardType {
  XP
  COINS
}

enum RewardReason {
  BET_PLACED
  BET_WON
  CLAIM_COMPLETED
  DAILY_BONUS
  WIN_STREAK
  LEVEL_UP
  REFERRAL_ACCEPTED
}

model User {
  id            String @id @default(uuid())
  walletAddress String @unique @map("wallet_address")

  // Optional self-edited profile fields. displayName is unique so we can
  // surface it in the leaderboard / activity feed without ambiguity; the
  // wallet address stays the immutable identity.
  displayName String? @unique @map("display_name")
  avatarUrl   String? @map("avatar_url")
  bannerUrl   String? @map("banner_url")

  // XP & Level
  totalXp BigInt @default(0) @map("total_xp")
  level   Int    @default(1)

  // UP Coins (8-decimal internal currency)
  coinsBalance  BigInt @default(0) @map("coins_balance")
  coinsLifetime BigInt @default(0) @map("coins_lifetime")
  coinsRedeemed BigInt @default(0) @map("coins_redeemed")

  // Stats
  totalBets    Int    @default(0) @map("total_bets")
  totalWins    Int    @default(0) @map("total_wins")
  totalWagered BigInt @default(0) @map("total_wagered")
  /// Lifetime payout received from claims (winning + refund claims). Net
  /// profit = totalWon − totalWagered. Drives the leaderboard Profit board.
  totalWon     BigInt @default(0) @map("total_won")
  /// Bets that reached a REAL resolution (win/loss, not refund). Farm-proof
  /// "active user" counter — drives the 20-bet reward, milestone eligibility
  /// and referral-prize validity. Incremented at normal resolution only.
  settledBets  Int    @default(0) @map("settled_bets")

  // Streaks
  currentStreak  Int       @default(0) @map("current_streak")
  bestStreak     Int       @default(0) @map("best_streak")
  lastActiveDate DateTime? @map("last_active_date")

  // Daily tracking
  dailyBetCount  Int       @default(0) @map("daily_bet_count")
  dailyCoins     BigInt    @default(0) @map("daily_coins")
  dailyResetDate DateTime? @map("daily_reset_date")

  // Referrals
  referralCode String? @unique @map("referral_code")
  referredBy   String? @map("referred_by")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  rewardLogs        RewardLog[]
  referralsGiven    Referral[]  @relation("referrer")
  referralsReceived Referral[]  @relation("referred")

  @@index([level])
  @@index([coinsLifetime])
  @@index([totalXp])
  @@map("users")
}

model RewardLog {
  id            String       @id @default(uuid())
  walletAddress String       @map("wallet_address")
  rewardType    RewardType   @map("reward_type")
  reason        RewardReason
  amount        BigInt
  metadata      Json?
  createdAt     DateTime     @default(now()) @map("created_at")

  user User @relation(fields: [walletAddress], references: [walletAddress])

  @@index([walletAddress, createdAt])
  @@index([rewardType])
  @@map("reward_logs")
}

/// One-time / per-key UP airdrops (20-bet reward, community milestones, …).
/// The unique (wallet, type) makes every grant idempotent — safe to retry.
model RewardGrant {
  id            String   @id @default(uuid())
  walletAddress String   @map("wallet_address")
  /// e.g. 'BET_MILESTONE_20', 'COMMUNITY_MILESTONE_STONE'.
  type          String
  /// UP coins granted, in stored units (display = /100).
  amount        BigInt
  meta          Json?
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([walletAddress, type])
  @@index([type])
  @@map("reward_grants")
}

model EmissionConfig {
  id               String    @id @default(uuid())
  epoch            Int       @unique
  coinsPerUsdcBet  BigInt    @map("coins_per_usdc_bet") // coins per $1 bet (8 decimals)
  winMultiplier    Int       @map("win_multiplier") // basis points (5000 = 50%)
  dailyCoinsCap    BigInt    @map("daily_coins_cap") // global daily cap
  epochStartDate   DateTime  @map("epoch_start_date")
  epochEndDate     DateTime? @map("epoch_end_date")
  totalAllocated   BigInt    @default(0) @map("total_allocated")
  totalDistributed BigInt    @default(0) @map("total_distributed")
  active           Boolean   @default(false)

  @@map("emission_configs")
}

model EventLog {
  id         String   @id @default(uuid())
  eventType  String   @map("event_type")
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  payload    Json
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([eventType])
  @@map("event_log")
}

model UptimeCheck {
  id        String   @id @default(uuid())
  status    String // operational, degraded, partial_outage
  services  Json // array of { name, status, latency?, details? }
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("uptime_checks")
}

// ─── Referral System ──────────────────────────────────────────────────────────

model Referral {
  id             String   @id @default(uuid())
  referrerWallet String   @map("referrer_wallet")
  referredWallet String   @unique @map("referred_wallet")
  createdAt      DateTime @default(now()) @map("created_at")

  // Anti-cheat signals captured when the referral is accepted.
  signupIp          String? @map("signup_ip")
  deviceFingerprint String? @map("device_fingerprint")
  // Flagged (not banned) when it looks like a sybil/self-referral — e.g. the
  // same device/IP as another referral from this referrer. Suspect referrals
  // are excluded from referrer rewards + the referral-prize leaderboard until
  // an admin reviews them.
  suspect       Boolean @default(false)
  suspectReason String? @map("suspect_reason")
  reviewed      Boolean @default(false)

  referrer User @relation("referrer", fields: [referrerWallet], references: [walletAddress])
  referred User @relation("referred", fields: [referredWallet], references: [walletAddress])

  @@index([referrerWallet, createdAt])
  @@index([deviceFingerprint])
  @@index([signupIp])
  @@map("referrals")
}

model ReferralEarning {
  id               String   @id @default(uuid())
  referrerWallet   String   @map("referrer_wallet")
  referredWallet   String   @map("referred_wallet")
  betId            String   @map("bet_id")
  poolId           String   @map("pool_id")
  feeAmount        BigInt   @map("fee_amount")
  commissionBps    Int      @default(2000) @map("commission_bps")
  commissionAmount BigInt   @map("commission_amount")
  paid             Boolean  @default(false)
  paidTx           String?  @map("paid_tx")
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([referrerWallet, createdAt])
  @@index([paid])
  @@map("referral_earnings")
}

model ReferralPayout {
  id            String   @id @default(uuid())
  walletAddress String   @map("wallet_address")
  amount        BigInt
  txSignature   String?  @map("tx_signature")
  status        String   @default("pending") // pending, completed, failed
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([walletAddress])
  @@map("referral_payouts")
}

// ─── Squad Pools ─────────────────────────────────────────────────────────────

model Squad {
  id            String   @id @default(uuid())
  name          String
  inviteCode    String   @unique @map("invite_code")
  creatorWallet String   @map("creator_wallet")
  maxMembers    Int      @default(20) @map("max_members")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  members  SquadMember[]
  pools    Pool[]         @relation("SquadPools")
  messages SquadMessage[]

  @@index([creatorWallet])
  @@map("squads")
}

model SquadMember {
  id            String    @id @default(uuid())
  squadId       String    @map("squad_id")
  walletAddress String    @map("wallet_address")
  role          SquadRole @default(MEMBER)
  joinedAt      DateTime  @default(now()) @map("joined_at")

  squad Squad @relation(fields: [squadId], references: [id])

  @@unique([squadId, walletAddress])
  @@index([walletAddress])
  @@map("squad_members")
}

model SquadMessage {
  id            String   @id @default(uuid())
  squadId       String   @map("squad_id")
  walletAddress String   @map("wallet_address")
  content       String
  createdAt     DateTime @default(now()) @map("created_at")

  squad Squad @relation(fields: [squadId], references: [id])

  @@index([squadId, createdAt])
  @@map("squad_messages")
}

// ─── Tournaments ─────────────────────────────────────────────────────────────

model Tournament {
  id               String    @id @default(uuid())
  name             String
  asset            String
  entryFee         BigInt    @map("entry_fee")
  size             Int // 8, 16, 32
  matchDuration    Int       @map("match_duration") // seconds - wait time after predictions
  predictionWindow Int       @default(300) @map("prediction_window") // seconds - time to predict
  status           String    @default("REGISTERING") // REGISTERING, ACTIVE, COMPLETED, CANCELLED
  currentRound     Int       @default(0) @map("current_round")
  totalRounds      Int       @map("total_rounds") // log2(size)
  prizePool        BigInt    @default(0) @map("prize_pool")
  winnerWallet     String?   @map("winner_wallet")
  prizeClaimedTx   String?   @map("prize_claimed_tx")
  scheduledAt      DateTime? @map("scheduled_at") // informational - estimated start time
  createdAt        DateTime  @default(now()) @map("created_at")
  startedAt        DateTime? @map("started_at")
  completedAt      DateTime? @map("completed_at")
  tournamentType   String    @default("CRYPTO") @map("tournament_type") // CRYPTO | SPORTS
  sport            String? // FOOTBALL
  league           String? // CL, PL, PD, etc.
  matchConfig      String?   @map("match_config") // JSON: pre-configured matches per round
  onChainPda       String?   @map("on_chain_pda") // Tournament PDA address (null = legacy)
  onChainVault     String?   @map("on_chain_vault") // Vault PDA address

  participants TournamentParticipant[]
  matches      TournamentMatch[]
  fixtures     TournamentRoundFixture[]

  @@index([status])
  @@map("tournaments")
}

model TournamentParticipant {
  id              String   @id @default(uuid())
  tournamentId    String   @map("tournament_id")
  walletAddress   String   @map("wallet_address")
  seed            Int
  eliminatedRound Int?     @map("eliminated_round")
  depositTx       String?  @map("deposit_tx")
  createdAt       DateTime @default(now()) @map("created_at")

  tournament Tournament @relation(fields: [tournamentId], references: [id])

  @@unique([tournamentId, walletAddress])
  @@index([tournamentId])
  @@map("tournament_participants")
}

model TournamentMatch {
  id                 String    @id @default(uuid())
  tournamentId       String    @map("tournament_id")
  round              Int
  matchIndex         Int       @map("match_index")
  player1Wallet      String?   @map("player1_wallet")
  player2Wallet      String?   @map("player2_wallet")
  player1Prediction  String?   @map("player1_prediction") // Crypto: numeric string. Sports: JSON {outcomes, totalGoals}
  player2Prediction  String?   @map("player2_prediction")
  player1PredictedAt DateTime? @map("player1_predicted_at")
  player2PredictedAt DateTime? @map("player2_predicted_at")
  player1TotalGoals  Int?      @map("player1_total_goals") // Sports tiebreaker
  player2TotalGoals  Int?      @map("player2_total_goals")
  player1Score       Int?      @map("player1_score") // Sports: correct predictions count
  player2Score       Int?      @map("player2_score")
  predictionDeadline DateTime? @map("prediction_deadline")
  startTime          DateTime? @map("start_time")
  endTime            DateTime? @map("end_time")
  strikePrice        String?   @map("strike_price") // Crypto only
  finalPrice         String?   @map("final_price") // Crypto: numeric. Sports: JSON outcomes
  winnerWallet       String?   @map("winner_wallet")
  status             String    @default("PENDING") // PENDING, ACTIVE, RESOLVED, BYE
  createdAt          DateTime  @default(now()) @map("created_at")
  resolvedAt         DateTime? @map("resolved_at")

  tournament Tournament @relation(fields: [tournamentId], references: [id])

  @@unique([tournamentId, round, matchIndex])
  @@index([tournamentId, round])
  @@map("tournament_matches")
}

model TournamentRoundFixture {
  id              String    @id @default(uuid())
  tournamentId    String    @map("tournament_id")
  round           Int
  fixtureIndex    Int       @map("fixture_index")
  footballMatchId String    @map("football_match_id")
  homeTeam        String    @map("home_team")
  awayTeam        String    @map("away_team")
  homeTeamCrest   String?   @map("home_team_crest")
  awayTeamCrest   String?   @map("away_team_crest")
  kickoff         DateTime?
  resultHome      Int?      @map("result_home")
  resultAway      Int?      @map("result_away")
  resultOutcome   String?   @map("result_outcome") // HOME | DRAW | AWAY
  status          String    @default("SCHEDULED") // SCHEDULED | LIVE | FINISHED
  createdAt       DateTime  @default(now()) @map("created_at")

  tournament Tournament @relation(fields: [tournamentId], references: [id])

  @@unique([tournamentId, round, fixtureIndex])
  @@index([tournamentId, round])
  @@map("tournament_round_fixtures")
}

model SportsFixtureCache {
  id             String   @id @default(uuid())
  externalId     String   @map("external_id")
  sport          String
  league         String
  leagueName     String   @map("league_name")
  season         Int?
  matchday       Int?
  homeTeam       String   @map("home_team")
  awayTeam       String   @map("away_team")
  homeTeamCrest  String?  @map("home_team_crest")
  awayTeamCrest  String?  @map("away_team_crest")
  kickoff        DateTime
  status         String   @default("SCHEDULED")
  homeScore      Int?     @map("home_score")
  awayScore      Int?     @map("away_score")
  winner         String?
  marketOdds     Float?   @map("market_odds")
  groupItemTitle String?  @map("group_item_title")
  clobTokenIds   String?  @map("clob_token_ids")
  tags           String? // JSON array of raw tag labels from Polymarket
  subcategory    String? // Single resolved subcategory bucket (carried to Pool on creation)
  // Polymarket markets settle via UMA → CTF on Polygon. We cache both
  // ids from Gamma; the resolver primarily uses conditionId (queries
  // ConditionalTokens at 0x4D97...6045, a single address for every PM
  // market regardless of which UMA adapter wrapped the request), and
  // questionId is kept around for a potential OO V2 fallback. Both are
  // bytes32 hex (0x… 64chars). Null for non-PM rows.
  questionId     String?  @map("question_id")
  conditionId    String?  @map("condition_id")
  apiSource      String   @default("sports") @map("api_source")
  lastSyncedAt   DateTime @map("last_synced_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([externalId, sport, apiSource])
  @@index([sport, league, kickoff])
  @@index([sport, league, status])
  @@index([status, kickoff])
  @@index([externalId])
  @@map("sports_fixture_cache")
}

/// Per-fighter image cache (combat sports — UFC, Boxing, K-1, …).
/// SDB exposes fighter photos via `searchplayers.php?p=<name>` but not on
/// the event endpoint. We cache results aggressively because (a) fighter
/// photos almost never change and (b) the same fighter appears across many
/// events, so a per-event lookup would 5× the SDB calls during sync.
///
/// Populated by services/sports/fighter-images.ts, read by
/// scheduler/fixture-sync.ts at upsert time, and surfaced through the
/// existing home_team_crest / away_team_crest columns on
/// sports_fixture_cache / Pool (no schema change needed downstream).
model FighterImageCache {
  nameKey       String   @id @map("name_key") // normalized: lowercase, single-spaced
  displayName   String   @map("display_name") // original casing from the first hit
  sport         String // 'Fighting' for SDB combat
  idPlayer      String?  @map("id_player") // SDB idPlayer when matched
  team          String? // 'UFC Welterweight' etc.
  thumbUrl      String?  @map("thumb_url") // strThumb — jpg headshot
  cutoutUrl     String?  @map("cutout_url") // strCutout — png, transparent
  notFound      Boolean  @default(false) @map("not_found")
  lastFetchedAt DateTime @default(now()) @map("last_fetched_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([sport])
  @@index([notFound, lastFetchedAt])
  @@map("fighter_image_cache")
}

// ─── Live Scores (DB fallback for TheSportsDB livescore cache) ────────────────

model LiveScore {
  eventId       String   @id @map("event_id") // TheSportsDB idEvent
  sport         String // 'Soccer', 'Ice Hockey', 'Basketball', etc.
  league        String // 'NHL', 'NBA', 'English Premier League', etc.
  homeTeam      String   @map("home_team")
  awayTeam      String   @map("away_team")
  homeScore     Int      @default(0) @map("home_score")
  awayScore     Int      @default(0) @map("away_score")
  status        String // Raw TheSportsDB status code (P1, Q2, HT, FT, etc.)
  progress      String   @default("") // '45', '90+3', 'Q3 8:42', etc.
  homeTeamBadge String   @default("") @map("home_team_badge")
  awayTeamBadge String   @default("") @map("away_team_badge")
  homeTeamNorm  String   @default("") @map("home_team_norm") // normalized: lowercase alphanumeric only
  updatedAt     DateTime @updatedAt @map("updated_at")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([sport, status])
  @@index([homeTeamNorm])
  @@map("live_scores")
}

// ─── Notifications (persisted, survives offline) ─────────────────────────────

model Notification {
  id            String   @id @default(uuid())
  walletAddress String   @map("wallet_address")
  type          String // POOL_WON, POOL_LOST, POOL_CLAIMABLE, REFUND_RECEIVED, etc.
  title         String
  message       String
  severity      String   @default("info") // success, info, warning, error
  poolId        String?  @map("pool_id")
  poolType      String?  @map("pool_type")
  read          Boolean  @default(false)
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([walletAddress, read])
  @@index([walletAddress, createdAt])
  @@map("notifications")
}

model PoolCategory {
  id           String   @id @default(uuid())
  code         String   @unique
  type         String // FOOTBALL_LEAGUE, SPORTSDB_SPORT, POLYMARKET, SPORT_GROUP
  enabled      Boolean  @default(true)
  comingSoon   Boolean  @default(false) @map("coming_soon")
  label        String
  shortLabel   String?  @map("short_label")
  color        String?
  badgeUrl     String?  @map("badge_url")
  /// Preferred background for the badge image. Auto-detected when SDB
  /// supplies a badge that's mostly white (white-on-transparent logos
  /// vanish on white backgrounds). Values: 'light' | 'dark' | '#RRGGBB'
  /// hex, or NULL = use frontend default.
  badgeBgColor String?  @map("badge_bg_color")
  iconKey      String?  @map("icon_key")
  apiSource    String?  @map("api_source")
  adapterKey   String?  @map("adapter_key")
  numSides     Int      @default(3) @map("num_sides")
  sideLabels   String[] @default(["Home", "Draw", "Away"]) @map("side_labels")
  config       Json?
  sortOrder    Int      @default(0) @map("sort_order")
  // Two-level hierarchy: SPORT_GROUP rows are umbrellas (Rugby, Football,
  // Basketball, ...); leagues point at their group via parentCode. No FK —
  // categories are operator-managed and we don't want a rename to cascade-
  // rewrite every child silently. Application layer validates the reference.
  parentCode   String?  @map("parent_code")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([type, enabled])
  @@index([parentCode])
  @@map("pool_categories")
}
