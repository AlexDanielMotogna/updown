# ── apps/terminal env ──────────────────────────────────────────────────────
# NEXT_PUBLIC_* are inlined at BUILD time — set them before `next build`.
# Copy to .env.local for dev. Do NOT put secrets here (everything here ships to
# the browser); server-side secrets live in apps/api.

# Privy (same app id as apps/web → SSO across *.updown.my)
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_PRIVY_CLIENT_ID=

# UpDown API (order/agent/link/resolve routes) — apps/api public URL
NEXT_PUBLIC_API_URL=http://localhost:3002

# UpDown web app — navbar/menu links (Markets / Profile / …)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# HyperLiquid endpoint. Mainnet:
#   NEXT_PUBLIC_HYPERLIQUID_API_URL=https://api.hyperliquid.xyz
#   NEXT_PUBLIC_HYPERLIQUID_TESTNET=false
# Testnet:
#   NEXT_PUBLIC_HYPERLIQUID_API_URL=https://api.hyperliquid-testnet.xyz
#   NEXT_PUBLIC_HYPERLIQUID_TESTNET=true
NEXT_PUBLIC_HYPERLIQUID_API_URL=https://api.hyperliquid.xyz
NEXT_PUBLIC_HYPERLIQUID_TESTNET=false
# Server-side read adapter (API routes) — keep in sync with the public URL above
HYPERLIQUID_API_URL=https://api.hyperliquid.xyz

# Builder code (PUBLIC address) — must match apps/api HYPERLIQUID_BUILDER_ADDRESS.
# The browser approveBuilderFee uses these. maxFeeRate is a percent string.
NEXT_PUBLIC_HYPERLIQUID_BUILDER_ADDRESS=
NEXT_PUBLIC_HYPERLIQUID_BUILDER_MAX_FEE=0.1%

# Optional — Solana RPC for Privy (defaults to devnet if unset)
# NEXT_PUBLIC_SOLANA_RPC_URL=

# Dev-only identity injection — leave UNSET in production
# NEXT_PUBLIC_DEV_WALLET=
# NEXT_PUBLIC_DEV_EVM_ADDRESS=
