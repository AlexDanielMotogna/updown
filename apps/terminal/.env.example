# ============================================================================
#  apps/terminal — environment template
#  NEXT_PUBLIC_* are inlined at BUILD time → set them before `next build`.
#  Copy to `.env.local` for dev. Everything NEXT_PUBLIC_ ships to the browser, so
#  put NO secrets here — server-side secrets live in apps/api.
# ============================================================================

# ── Auth (Privy) ────────────────────────────────────────────────────────────
# MUST be the SAME Privy app id as apps/web → single sign-on across *.updown.my.
# REQUIRED.
#
# ⚠️ For the SSO to work (no second login when landing on the terminal) prod MUST
# use the PRODUCTION Privy app id (server-set cookie, Domain=.updown.my, shared
# across subdomains). A DEVELOPMENT app id sets a host-only cookie that is never
# shared → the terminal keeps prompting for login. Use dev id locally, prod id in
# Railway prod (same value as apps/web). Full explanation in apps/web/.env.example.
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_PRIVY_CLIENT_ID=

# ── Links to the rest of the stack ──────────────────────────────────────────
# UpDown API (order / agent / link / resolve routes) — apps/api public URL.
NEXT_PUBLIC_API_URL=http://localhost:3002
# UpDown web app — navbar/menu links back to Markets / Profile / …
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── HyperLiquid endpoint ────────────────────────────────────────────────────
# Mainnet:  https://api.hyperliquid.xyz            + TESTNET=false
# Testnet:  https://api.hyperliquid-testnet.xyz    + TESTNET=true
NEXT_PUBLIC_HYPERLIQUID_API_URL=https://api.hyperliquid.xyz
NEXT_PUBLIC_HYPERLIQUID_TESTNET=false
# Server-side read adapter (API routes) — keep in sync with the public URL above.
HYPERLIQUID_API_URL=https://api.hyperliquid.xyz

# ── Builder code (fee) ──────────────────────────────────────────────────────
# PUBLIC builder address — must match HYPERLIQUID_BUILDER_ADDRESS in apps/api.
# The browser approveBuilderFee call uses these; maxFee is a percent string.
NEXT_PUBLIC_HYPERLIQUID_BUILDER_ADDRESS=
NEXT_PUBLIC_HYPERLIQUID_BUILDER_MAX_FEE=0.1%

# ── Optional ────────────────────────────────────────────────────────────────
# Solana RPC for Privy embedded wallets (defaults to devnet if unset).
# NEXT_PUBLIC_SOLANA_RPC_URL=
# Dev-only identity injection — leave UNSET in production.
# NEXT_PUBLIC_DEV_WALLET=
# NEXT_PUBLIC_DEV_EVM_ADDRESS=
