# ============================================================================
#  apps/web — environment template
#  NEXT_PUBLIC_* are inlined at BUILD time → set them before `next build`.
#  Copy to `.env` (or `.env.local`) for dev. Anything NEXT_PUBLIC_ ships to the
#  browser — never put secrets in those. On Vercel/Railway set per environment.
# ============================================================================

# ── Auth (Privy) ────────────────────────────────────────────────────────────
# MUST be the SAME Privy app id as apps/terminal → single sign-on across
# *.updown.my (updown.my ↔ terminal.updown.my). REQUIRED.
#
# ⚠️ DEV vs PROD app id — this is what makes the SSO work:
#   • PRODUCTION app id → Privy's SERVER sets the session cookie scoped to your
#     verified domain AND its subdomains (Domain=.updown.my) → shared, so going
#     to Trade does NOT ask to log in again. Locked to the verified domain
#     (won't work on localhost). 30-day cookie.
#   • DEVELOPMENT app id → Privy's CLIENT sets a HOST-ONLY cookie (Domain=updown.my,
#     no dot) that works on any host incl. localhost but is NEVER shared with
#     subdomains → the terminal keeps asking to log in. 7-day cookie.
# So: use the DEV app id locally, and the PROD app id in Railway prod (both web
# AND terminal), with HttpOnly cookies ON + App domain updown.my verified +
# SameSite Lax in the Privy dashboard. Prod requires a redeploy (NEXT_PUBLIC_*).
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_PRIVY_CLIENT_ID=

# ── Backend / links ─────────────────────────────────────────────────────────
# UpDown API base URL (pools, profile, admin, etc.). REQUIRED.
NEXT_PUBLIC_API_URL=http://localhost:3002
# Trading terminal URL — powers the "Trade" nav link. Defaults to :3010.
NEXT_PUBLIC_TERMINAL_URL=http://localhost:3010

# ── Solana ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
# USDC mint — MUST match USDC_MINT in apps/api.
# Devnet: By87mHK9Meinfv4AEqTx9qyYmGDLUcwiywpkkCWwGUVz
# Mainnet: EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
NEXT_PUBLIC_USDC_MINT=By87mHK9Meinfv4AEqTx9qyYmGDLUcwiywpkkCWwGUVz

# ── Media uploads (Cloudinary) ──────────────────────────────────────────────
# Profile avatar + banner uploads. Create an UNSIGNED upload preset at
# cloudinary.com → Settings → Upload → Upload presets. Without these the profile
# dialog falls back to URL paste only (no in-app uploader).
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# ── Server-side (NOT exposed to the browser) ────────────────────────────────
# Anthropic key for the web API route(s) that call Claude. Optional.
ANTHROPIC_API_KEY=

# ── Optional / dev flags ────────────────────────────────────────────────────
# Environment label shown in the UI (e.g. a dev/prod badge). dev | prod
# NEXT_PUBLIC_ENV=dev
# Set to 1 to log the bet-flash animation for debugging. Leave unset normally.
# NEXT_PUBLIC_DEBUG_BET_FLASH=

# --- Feature gates ---
# UP-coin Store/Inventory + boost UI. Auto-on in dev; hidden in prod. Override: true|false.
# NEXT_PUBLIC_ENABLE_STORE=
# Production lockdown: redirect the whole app to /worldcup. Set true ONLY in production.
# NEXT_PUBLIC_PROD_LOCKDOWN=
# Environment tag (LOCAL|DEV|PROD) — set explicitly per env so the gates detect correctly.
# NEXT_PUBLIC_ENV=

# ── Web Push (VAPID public key) ─────────────────────────────────────────────
# MUST match VAPID_PUBLIC_KEY in apps/api. Public — inlined into the browser
# bundle at build time (NEXT_PUBLIC_*). Without it the "Enable alerts" toggle
# stays disabled.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
