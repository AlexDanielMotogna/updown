# Solana Configuration
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# Program IDs
NEXT_PUBLIC_PROGRAM_ID=YOUR_PROGRAM_ID_HERE
NEXT_PUBLIC_USDC_MINT=Gh9ZwEmdLJ8DscKNTkTqPbNwLNNBjuSzaG9Vp2KGtKJr

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:4000

# Feature Flags
NEXT_PUBLIC_ENABLE_TESTNET=true

# Cloudinary (profile avatar + banner uploads)
# Sign up free at https://cloudinary.com and create an unsigned upload preset
# in Settings → Upload → Upload presets. Without these set the profile dialog
# falls back to URL paste only (no in-app uploader).
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
